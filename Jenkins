pipeline {
    agent any

    environment {
        S3_BUCKET = 's3://jenkinsbackupsuvam'
    }

    stages {

        stage('Archive & Compress') {
            steps {
                echo "Packaging files from workspace..."
                sh '''
                tar --exclude='.git' --exclude='*.tar.gz' \
                -czf jenkins-project.tar.gz .
                '''
            }
        }

        stage('Upload to AWS S3') {
            steps {
                echo "Uploading artifact to S3..."
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding',
                  credentialsId: 'aws-s3-backup-creds']]) {

                    sh "aws s3 cp jenkins-project.tar.gz ${S3_BUCKET}/backups2/"
                }
            }
        }
    }

    post {
        always {
            echo "Cleaning workspace..."
            sh '[ -f jenkins-project.tar.gz ] && rm jenkins-project.tar.gz || true'
        }
        success {
            echo "Upload successful!"
        }
        failure {
            echo "Pipeline failed. Check logs."
        }
    }
}
